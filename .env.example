# PostgreSQL
DATABASE_URL=postgresql+asyncpg://usuario:senha@localhost:5432/cadastro_db

# Redis
REDIS_URL=redis://localhost:6379/0

# JWT — troque por uma chave segura em produção
SECRET_KEY=change-me-to-a-random-secret

# Auth
AUTH_USERNAME=admin
AUTH_PASSWORD=change-me-to-a-strong-password

# FastAPI
DEBUG=false
